# ── Server ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/iptvapp
# For MongoDB Atlas (production):
# MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/iptvapp

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=replace_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
# Stripe price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_MONTHLY=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_YEARLY=price_xxxxxxxxxxxxxxxxxxxx

# ── XUI.ONE Panel ─────────────────────────────────────────
XUIONE_BASE_URL=http://YOUR_VPS_IP:25461
XUIONE_USERNAME=admin
XUIONE_PASSWORD=your_admin_password

# ── App ───────────────────────────────────────────────────
# Your XUI.ONE portal URL — given to subscribers in the app
IPTV_PORTAL_URL=http://YOUR_VPS_IP:8080
CLIENT_URL=http://localhost:3000
# Stripe redirects to this HTTP URL; the backend then redirects to the deep link
STRIPE_REDIRECT_BASE_URL=http://localhost:5001
APP_DEEP_LINK=smartiptv://
